{erl_opts, [debug_info]}.

{deps, []}.

%% Cargo build hooks for all NIFs
%% Server-side NIFs (used by reckon-db):
%%   - esdb_crypto_nif: Ed25519 verify, SHA256, secure compare
%%   - esdb_archive_nif: LZ4 compression
%%   - esdb_hash_nif: xxHash, FNV-1a
%%   - esdb_aggregate_nif: Event aggregation
%%   - esdb_filter_nif: Regex/pattern matching
%%   - esdb_graph_nif: Graph algorithms
%% Client-side NIFs (used by reckon-gater):
%%   - esdb_gater_crypto_nif: Base58, resource pattern matching
{pre_hooks, [
    {compile, "cargo build --release --manifest-path native/esdb_crypto_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/esdb_archive_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/esdb_hash_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/esdb_aggregate_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/esdb_filter_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/esdb_graph_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/esdb_gater_crypto_nif/Cargo.toml"}
]}.

%% Copy compiled .so files to priv/
{post_hooks, [
    {compile, "sh -c 'mkdir -p priv && for lib in crypto archive hash aggregate filter graph gater_crypto; do cp native/esdb_${lib}_nif/target/release/libesdb_${lib}_nif.so priv/esdb_${lib}_nif.so 2>/dev/null || cp native/esdb_${lib}_nif/target/release/libesdb_${lib}_nif.dylib priv/esdb_${lib}_nif.so 2>/dev/null || true; done'"}
]}.

{shell, [
    {apps, [reckon_nifs]}
]}.

%% Profiles
{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]}
    ]}
]}.

%% Hex.pm package metadata
{hex, [
    {doc, #{provider => ex_doc}}
]}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

{ex_doc, [
    {source_url, <<"https://github.com/reckon-db-org/reckon-nifs">>},
    {extras, [<<"README.md">>, <<"CHANGELOG.md">>, <<"LICENSE">>]},
    {main, <<"README.md">>}
]}.
