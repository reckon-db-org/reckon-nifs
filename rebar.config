{erl_opts, [debug_info]}.

{deps, []}.

%% Cargo build hooks for all NIFs
%% Server-side NIFs (consumed by reckon-db via
%% `code:priv_dir(reckon_nifs)/<name>` from each wrapper module's
%% `-on_load(init/0)` hook):
%%   - reckon_db_crypto_nif: Ed25519 verify, SHA256, secure compare
%%   - reckon_db_archive_nif: LZ4 compression
%%   - reckon_db_hash_nif: xxHash, FNV-1a
%%   - reckon_db_aggregate_nif: Event aggregation
%%   - reckon_db_filter_nif: Regex/pattern matching
%%   - reckon_db_graph_nif: Graph algorithms
%% Client-side NIFs (consumed by reckon-gater):
%%   - reckon_gater_crypto_nif: Base58, resource pattern matching
{pre_hooks, [
    {compile, "cargo build --release --manifest-path native/reckon_db_crypto_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/reckon_db_archive_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/reckon_db_hash_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/reckon_db_aggregate_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/reckon_db_filter_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/reckon_db_graph_nif/Cargo.toml"},
    {compile, "cargo build --release --manifest-path native/reckon_gater_crypto_nif/Cargo.toml"}
]}.

%% Copy compiled .so files to priv/. Crate names are enumerated
%% explicitly because the gater crate breaks the `reckon_db_*` prefix.
{post_hooks, [
    {compile, "sh -c 'mkdir -p priv && for crate in reckon_db_crypto_nif reckon_db_archive_nif reckon_db_hash_nif reckon_db_aggregate_nif reckon_db_filter_nif reckon_db_graph_nif reckon_gater_crypto_nif; do cp native/${crate}/target/release/lib${crate}.so priv/${crate}.so 2>/dev/null || cp native/${crate}/target/release/lib${crate}.dylib priv/${crate}.so 2>/dev/null || true; done'"}
]}.

{shell, [
    {apps, [reckon_nifs]}
]}.

%% Profiles
{profiles, [
    {test, [
        {erl_opts, [debug_info, nowarn_export_all]}
    ]}
]}.

%% Hex.pm package metadata
{hex, [
    {doc, #{provider => ex_doc}}
]}.

{project_plugins, [rebar3_hex, rebar3_ex_doc]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/reckon-db-org/reckon-nifs">>},
    {extras, [<<"README.md">>, <<"CHANGELOG.md">>, <<"LICENSE">>]},
    {main, <<"README.md">>}
]}.
